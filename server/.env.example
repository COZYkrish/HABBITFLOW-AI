# Backend Environment Configuration
# Copy this file to .env and fill in the values before running the server.

# Application Environment (development, production)
NODE_ENV=development

# Server Port
PORT=5000

# API Prefix
API_PREFIX=/api/v1

# MongoDB Connection String (Required)
# Use a local MongoDB instance or MongoDB Atlas cluster.
MONGO_URI=mongodb://localhost:27017/habitflow

# JWT Secret Key (Required)
# Use a strong randomly generated string for production.
JWT_SECRET=supersecretjwtkeythatshouldbechanged

# JWT Expiration Time (e.g., 1h, 7d)
JWT_EXPIRES_IN=7d

# Frontend URL (For CORS)
# Local development: http://localhost:5173
# Production: https://your-habitflow-frontend.vercel.app
FRONTEND_URL=http://localhost:5173
