# ==========================================
# HabitFlow AI - Environment Configuration
# ==========================================
# Copy this file to .env in both /client and /server
# Adjust the values below according to your environment.

# ------------------------------------------
# Server (Backend) Configuration
# ------------------------------------------
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# MongoDB Configuration
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/habitflow?retryWrites=true&w=majority

# Security / JWT
JWT_SECRET=your_jwt_secret_placeholder_here
JWT_EXPIRES_IN=7d

# CORS configuration
FRONTEND_URL=http://localhost:5173

# Email / Nodemailer (Configuration Only)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_email_user
EMAIL_PASS=your_email_pass

# ------------------------------------------
# Client (Frontend) Configuration
# ------------------------------------------
# Vite requires VITE_ prefix for client-exposed variables
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_ENVIRONMENT=development
